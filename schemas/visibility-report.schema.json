{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentfeed.org/schemas/visibility-report.schema.json",
  "title": "Visibility Report",
  "description": "Customer-facing AI search visibility summary.",
  "type": "object",
  "properties": {
    "source_id": { "type": "string" },
    "source_name": { "type": "string" },
    "report_date": { "type": "string", "format": "date" },
    "afo_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "afo_score_label": { "type": "string", "enum": ["Needs Work", "Getting Started", "Good", "Strong", "Excellent"] },
    "summary_text": { "type": "string" },
    "improvements": { "type": "array", "items": { "type": "string" } },
    "issues": { "type": "array", "items": { "type": "string" } },
    "competitor_comparison": { "type": "array" },
    "recommended_updates": { "type": "array" },
    "diy_instructions_url": { "type": "string" },
    "upgrade_url": { "type": "string" }
  }
}
