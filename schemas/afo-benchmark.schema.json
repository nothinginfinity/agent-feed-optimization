{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentfeed.org/schemas/afo-benchmark.schema.json",
  "title": "AFO Benchmark",
  "description": "ABENCH-001: Controlled benchmark test for agent search visibility.",
  "type": "object",
  "required": ["benchmark_id", "prompt", "source_id", "agent_name", "model_name", "runs"],
  "properties": {
    "benchmark_id": { "type": "string" },
    "industry": { "type": "string" },
    "region": { "type": "string" },
    "prompt": { "type": "string" },
    "source_id": { "type": "string" },
    "competitor_ids": { "type": "array", "items": { "type": "string" } },
    "agent_name": { "type": "string" },
    "model_name": { "type": "string" },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "appeared": { "type": "boolean" },
          "rank": { "type": ["integer", "null"] },
          "cited": { "type": "boolean" },
          "used_afo_context": { "type": "boolean" },
          "included_action": { "type": "boolean" },
          "answer_quality_score": { "type": "integer", "minimum": 0, "maximum": 3 },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
